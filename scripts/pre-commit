#!/bin/sh
# Install this hook by running:
#   cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "Running ktlint..."
./gradlew ktlintCheck --daemon
KTLINT_STATUS=$?

echo "Running detekt..."
./gradlew detekt --daemon
DETEKT_STATUS=$?

if [ $KTLINT_STATUS -ne 0 ]; then
  echo ""
  echo "ktlint failed. Run './gradlew ktlintFormat' to auto-fix formatting issues."
  exit 1
fi

if [ $DETEKT_STATUS -ne 0 ]; then
  echo ""
  echo "detekt failed. Review the report above and fix the issues before committing."
  exit 1
fi

echo "All checks passed."
exit 0
