<?xml version="1.0" encoding="utf-8"?>
<!-- Warm Cream widget surface. Light scheme: flat cream with a hairline outline-variant
     border for containment on arbitrary wallpapers. Dark variant lives in drawable-night. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFDE7" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#CAC4D0" />
</shape>
