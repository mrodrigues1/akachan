<?xml version="1.0" encoding="utf-8"?>
<!-- Milk stash widget surface. surfaceVariant with a hairline border so the rounded surface
     stays contained on arbitrary wallpapers. Matches the Inventory home tile. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/widget_surface_variant" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#CAC4D0" />
</shape>
